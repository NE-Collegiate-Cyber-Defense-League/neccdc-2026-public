{# Packages: sudo package and sudoers configuration #}
<package>
    <name>sudo</name>
    <pkginfolink>https://docs.netgate.com/pfsense/en/latest/packages/sudo.html</pkginfolink>
    <descr><![CDATA[sudo allows delegation of privileges to users in the shell so commands can be run as other users, such as root.]]></descr>
    <website>http://www.sudo.ws/</website>
    <version>0.3.1</version>
    <configurationfile>sudo.xml</configurationfile>
    <include_file>/usr/local/pkg/sudo.inc</include_file>
    <plugins>
        <item>
            <type>plugin_xmlrpc_send</type>
        </item>
        <item>
            <type>plugin_xmlrpc_recv</type>
        </item>
        <item>
            <type>plugin_xmlrpc_recv_done</type>
        </item>
    </plugins>
</package>
<sudo>
    <config>
        <row>
            <username><![CDATA[user:black-team]]></username>
            <runas>user:root</runas>
            <nopasswd>ON</nopasswd>
            <cmdlist>ALL</cmdlist>
        </row>
        <row>
            <username><![CDATA[user:root]]></username>
            <runas>user:root</runas>
            <cmdlist>ALL</cmdlist>
        </row>
        <row>
            <username><![CDATA[user:admin]]></username>
            <runas>user:root</runas>
            <cmdlist>ALL</cmdlist>
        </row>
        <row>
            <username><![CDATA[group:admins]]></username>
            <runas>user:root</runas>
            <nopasswd>ON</nopasswd>
            <cmdlist>ALL</cmdlist>
        </row>
        <row>
            <username><![CDATA[group:network_admins]]></username>
            <runas>user:root</runas>
            <cmdlist>ALL</cmdlist>
        </row>
        <row>
            <username><![CDATA[user:ahawkins]]></username>
            <runas>user:root</runas>
            <cmdlist>ALL</cmdlist>
        </row>
        <add_includedir>include_start</add_includedir>
    </config>
</sudo>
<menu>
    <name>sudo</name>
    <section>System</section>
    <url>/pkg_edit.php?xml=sudo.xml</url>
</menu>